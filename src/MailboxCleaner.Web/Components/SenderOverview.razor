<h2>Sender overview</h2>

<div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Filters</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleFilterPanel">@(showFilters ? "Hide" : "Show") filters</button>
    </div>
    @if (showFilters)
    {
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Search sender</label>
                    <input class="form-control" @bind="SearchTerm" @bind:event="oninput" placeholder="Search by name or email" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Domain</label>
                    <input class="form-control" list="domain-options" @bind="DomainFilter" @bind:event="oninput" />
                    <datalist id="domain-options">
                        @foreach (var domain in availableDomains)
                        {
                            <option value="@domain"></option>
                        }
                    </datalist>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select class="form-select" @bind="MessageStatusFilter">
                        <option value="">All</option>
                        <option value="Unread">Unread</option>
                        <option value="Read">Read</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Folder</label>
                    <select class="form-select" @bind="FolderFilter">
                        <option value="">All</option>
                        @foreach (var folder in ExistingFolders)
                        {
                            <option value="@folder">@folder</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Attachments</label>
                    <select class="form-select" @bind="AttachmentFilterValue">
                        <option value="">All</option>
                        <option value="true">With attachment</option>
                        <option value="false">No attachment</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Autocomplete sender/keyword</label>
                    <input class="form-control" list="message-query-options" @bind="MessageQuery" @bind:event="oninput" placeholder="Search sender or keyword" />
                    <datalist id="message-query-options">
                        @foreach (var suggestion in querySuggestions)
                        {
                            <option value="@suggestion"></option>
                        }
                    </datalist>
                </div>
                <div class="col-md-2">
                    <div class="form-check mt-4">
                        <input class="form-check-input" type="checkbox" id="noreplyOnly" @bind="NoreplyOnly" />
                        <label class="form-check-label" for="noreplyOnly">Noreply only</label>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (isLoading)
{
    <div class="alert alert-info">Loading Gmail metadata…</div>
}
else if (!filteredSenders.Any())
{
    <div class="alert alert-warning">No senders found.</div>
}
else
{
    <div class="mb-3 text-muted">Selected messages: @engine.SelectedMessageIds.Count</div>

    @foreach (var sender in filteredSenders)
    {
        var senderMessages = filteredMessages.Where(message => message.SenderEmail.Equals(sender.Email, StringComparison.OrdinalIgnoreCase)).ToList();
        if (!senderMessages.Any())
        {
            continue;
        }

        var senderExpanded = engine.ExpandedSenders.Contains(sender.Email);
        <div class="card mb-2">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <input type="checkbox" checked="@engine.IsSenderFullySelected(sender.Email)" @onchange="(args) => ToggleSenderSelection(sender.Email, args)" />
                    <button class="btn btn-sm btn-link text-decoration-none" @onclick="() => ToggleSender(sender.Email)">
                        @sender.Name (@sender.Email) - @senderMessages.Count mails
                    </button>
                </div>
                <span class="badge text-bg-secondary">@sender.Count total</span>
            </div>
            @if (senderExpanded)
            {
                <div class="card-body p-0">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Title</th>
                                <th>Received</th>
                                <th>Attachment</th>
                                <th>Status</th>
                                <th>Folder</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var message in senderMessages)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" checked="@engine.SelectedMessageIds.Contains(message.Id)" @onchange="(args) => ToggleMessageSelection(message.Id, args)" />
                                    </td>
                                    <td>@message.Subject</td>
                                    <td>@(message.ReceivedAt?.ToString("yyyy-MM-dd") ?? "Unknown")</td>
                                    <td>@(message.HasAttachment ? "Yes" : "No")</td>
                                    <td>@(message.IsRead ? "Read" : "Unread")</td>
                                    <td>@message.Folder</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    <div class="card mt-4">
        <div class="card-header">Bulk actions</div>
        <div class="card-body d-flex flex-wrap gap-2">
            <button class="btn btn-outline-danger" @onclick="() => OpenActionPane(MailBulkAction.Delete)">Delete</button>
            <button class="btn btn-outline-primary" @onclick="() => OpenActionPane(MailBulkAction.Archive)">Archive</button>
            <button class="btn btn-outline-secondary" @onclick="() => OpenActionPane(MailBulkAction.MarkRead)">Mark as read</button>
            <button class="btn btn-outline-secondary" @onclick="() => OpenActionPane(MailBulkAction.MarkUnread)">Mark as unread</button>
            <button class="btn btn-outline-warning" @onclick="() => OpenActionPane(MailBulkAction.Move)">Move to folder</button>
        </div>
    </div>
}

@if (showActionPane && pendingAction.HasValue)
{
    <div class="card mt-3 border-warning">
        <div class="card-header">Confirm action</div>
        <div class="card-body">
            <p>You are about to apply <strong>@pendingAction</strong> on <strong>@actionPreview?.SelectedCount</strong> messages.</p>

            @if (pendingAction == MailBulkAction.Move)
            {
                <div class="row g-2 align-items-end">
                    <div class="col-md-6">
                        <label class="form-label">Destination folder</label>
                        <select class="form-select" @bind="selectedDestinationFolder">
                            @foreach (var folder in ExistingFolders)
                            {
                                <option value="@folder">@folder</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Or create a new folder</label>
                        <input class="form-control" @bind="newFolderName" placeholder="Enter folder name" />
                    </div>
                </div>
            }

            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="ConfirmAction">Confirm</button>
                <button class="btn btn-outline-secondary" @onclick="CancelAction">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private bool showFilters = true;
    private string searchTerm = string.Empty;
    private string domainFilter = string.Empty;
    private bool noreplyOnly;

    private List<SenderStatDto> allSenders = new();
    private List<SenderStatDto> filteredSenders = new();
    private List<string> availableDomains = new();

    private IReadOnlyCollection<MailItemDto> allMessages = Array.Empty<MailItemDto>();
    private IReadOnlyCollection<MailItemDto> filteredMessages = Array.Empty<MailItemDto>();
    private List<string> querySuggestions = new();

    private string messageQuery = string.Empty;
    private string messageStatusFilter = string.Empty;
    private string folderFilter = string.Empty;
    private string attachmentFilterValue = string.Empty;

    private MailManagementEngine engine = new(Array.Empty<MailItemDto>());

    private bool showActionPane;
    private MailBulkAction? pendingAction;
    private ActionPreview? actionPreview;
    private string selectedDestinationFolder = "Inbox";
    private string newFolderName = string.Empty;

    private IEnumerable<string> ExistingFolders => allMessages.Select(message => message.Folder)
        .Where(folder => !string.IsNullOrWhiteSpace(folder))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(folder => folder);

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        isLoading = true;
        StateHasChanged();

        allSenders = (await OverviewService.GetOverviewAsync(new GetSenderOverviewQuery(), CancellationToken.None)).ToList();
        allMessages = (await OverviewService.GetMailItemsAsync(CancellationToken.None)).ToList();

        engine = new MailManagementEngine(allMessages);

        availableDomains = allSenders.Select(sender => sender.Domain)
            .Where(domain => !string.IsNullOrWhiteSpace(domain))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(domain => domain)
            .ToList();

        ApplyFilters();
        isLoading = false;
    }

    private void ApplyFilters()
    {
        IEnumerable<SenderStatDto> senderResults = allSenders;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            senderResults = senderResults.Where(sender =>
                sender.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
                || sender.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(domainFilter))
        {
            senderResults = senderResults.Where(sender => sender.Domain.Contains(domainFilter, StringComparison.OrdinalIgnoreCase));
        }

        if (noreplyOnly)
        {
            senderResults = senderResults.Where(sender => sender.Email.Contains("noreply", StringComparison.OrdinalIgnoreCase));
        }

        filteredSenders = senderResults.OrderByDescending(sender => sender.Count).ToList();

        filteredMessages = engine.FilterMessages(messageQuery, messageStatusFilter, folderFilter, ParseAttachmentFilter());
        querySuggestions = engine.AutocompleteSuggestions(messageQuery).ToList();
    }

    private bool? ParseAttachmentFilter() => attachmentFilterValue switch
    {
        "true" => true,
        "false" => false,
        _ => null
    };

    private void ToggleSender(string senderEmail)
    {
        engine.ToggleSenderExpansion(senderEmail);
    }

    private void ToggleSenderSelection(string senderEmail, ChangeEventArgs args)
    {
        var isChecked = args.Value is bool value && value;
        engine.ToggleSenderSelection(senderEmail, isChecked);
    }

    private void ToggleMessageSelection(string messageId, ChangeEventArgs args)
    {
        var isChecked = args.Value is bool value && value;
        engine.ToggleMessageSelection(messageId, isChecked);
    }

    private void OpenActionPane(MailBulkAction action)
    {
        pendingAction = action;
        showActionPane = true;
        actionPreview = engine.PreviewAction(action, selectedDestinationFolder);
    }

    private void ConfirmAction()
    {
        if (!pendingAction.HasValue)
        {
            return;
        }

        if (pendingAction == MailBulkAction.Move && !string.IsNullOrWhiteSpace(newFolderName))
        {
            selectedDestinationFolder = newFolderName.Trim();
        }

        engine.ApplyAction(pendingAction.Value, selectedDestinationFolder);
        allMessages = engine.FilterMessages(string.Empty, string.Empty, string.Empty, null).ToList();
        ApplyFilters();
        CancelAction();
    }

    private void CancelAction()
    {
        showActionPane = false;
        pendingAction = null;
        actionPreview = null;
        newFolderName = string.Empty;
    }

    private void ToggleFilterPanel() => showFilters = !showFilters;

    private string SearchTerm
    {
        get => searchTerm;
        set
        {
            searchTerm = value;
            ApplyFilters();
        }
    }

    private string DomainFilter
    {
        get => domainFilter;
        set
        {
            domainFilter = value;
            ApplyFilters();
        }
    }

    private bool NoreplyOnly
    {
        get => noreplyOnly;
        set
        {
            noreplyOnly = value;
            ApplyFilters();
        }
    }

    private string MessageQuery
    {
        get => messageQuery;
        set
        {
            messageQuery = value;
            ApplyFilters();
        }
    }

    private string MessageStatusFilter
    {
        get => messageStatusFilter;
        set
        {
            messageStatusFilter = value;
            ApplyFilters();
        }
    }

    private string FolderFilter
    {
        get => folderFilter;
        set
        {
            folderFilter = value;
            ApplyFilters();
        }
    }

    private string AttachmentFilterValue
    {
        get => attachmentFilterValue;
        set
        {
            attachmentFilterValue = value;
            ApplyFilters();
        }
    }
}
